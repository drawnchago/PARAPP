@page "/catalogos/paises"
@inject ApiService Api
@inject SessionService Session
@inject NavigationManager Nav

<div class="module-container">
    <div class="module-header">
        <h2>🌎 Países</h2>
        @if (permission?.PuedeCrear == true)
        {
            <button class="btn btn-primary" @onclick="OpenCreate">+ Nuevo país</button>
        }
    </div>

    <div class="catalog-toolbar">
        <input type="search" class="form-control" @bind="query" @bind:event="oninput"
               placeholder="Buscar por nombre o código..." />
        <button class="btn btn-outline-secondary" @onclick="Load">Buscar</button>
    </div>

    @if (loading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <div class="catalog-list">
            @foreach (var item in items)
            {
                <div class="catalog-row @(!item.IsActive ? "inactive" : "")">
                    <div class="catalog-code">@item.Code</div>
                    <div class="catalog-info">
                        <strong>@item.Name</strong>
                        <small>Actualizado: @item.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                    </div>
                    <span class="chip @(item.IsActive ? "chip-success" : "chip-warning")">
                        @(item.IsActive ? "Activo" : "Inactivo")
                    </span>
                    <div class="item-actions">
                        @if (permission?.PuedeEditar == true)
                        {
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenEdit(item)">Editar</button>
                        }
                        @if (permission?.PuedeEliminar == true && item.IsActive)
                        {
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => Deactivate(item.Id)">Desactivar</button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal-card" @onclick:stopPropagation>
            <h4>@(editingId.HasValue ? "Editar país" : "Nuevo país")</h4>
            <div class="mb-3">
                <label class="form-label">Código ISO de 3 caracteres *</label>
                <input class="form-control text-uppercase" maxlength="3" @bind="form.Code" />
            </div>
            <div class="mb-3">
                <label class="form-label">Nombre *</label>
                <input class="form-control" @bind="form.Name" />
            </div>
            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="countryActive" @bind="form.IsActive" />
                <label class="form-check-label" for="countryActive">Activo</label>
            </div>
            @if (error != null) { <div class="alert alert-danger py-2">@error</div> }
            <div class="d-flex gap-2 justify-content-end">
                <button class="btn btn-secondary" @onclick="CloseForm">Cancelar</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@saving">@(saving ? "Guardando..." : "Guardar")</button>
            </div>
        </div>
    </div>
}

@code {
    private List<CountryDto> items = [];
    private ModuloPermiso? permission;
    private CountryCatalogForm form = new();
    private uint? editingId;
    private string query = "";
    private string? error;
    private bool loading = true, saving, showForm;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        permission = Session.ObtenerPermiso("countries");
        if (permission?.PuedeVer != true) { Nav.NavigateTo("/"); return; }
        await Load();
    }

    private async Task Load() { loading = true; items = await Api.GetAdminCountriesAsync(query); loading = false; }
    private void OpenCreate() { editingId = null; form = new(); error = null; showForm = true; }
    private void OpenEdit(CountryDto item)
    {
        editingId = item.Id;
        form = new() { Code = item.Code, Name = item.Name, IsActive = item.IsActive };
        error = null; showForm = true;
    }
    private void CloseForm() => showForm = false;
    private async Task Save()
    {
        if (form.Code.Trim().Length != 3 || string.IsNullOrWhiteSpace(form.Name))
        { error = "Código de tres caracteres y nombre son requeridos."; return; }
        saving = true;
        var ok = editingId.HasValue
            ? await Api.UpdateCountryAsync(editingId.Value, form) != null
            : await Api.CreateCountryAsync(form) != null;
        saving = false;
        if (!ok) { error = "No se pudo guardar. Verifica que el código no esté repetido."; return; }
        showForm = false; await Load();
    }
    private async Task Deactivate(uint id) { if (await Api.DeactivateCountryAsync(id)) await Load(); }
}
