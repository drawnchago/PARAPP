@page "/donaciones"
@inject ApiService Api
@inject SessionService Session
@inject NavigationManager Nav

<div class="module-container">
    <div class="module-header">
        <h2>💝 Donaciones</h2>
        @if (permiso?.PuedeCrear == true)
        {
            <button class="btn btn-primary" @onclick="AbrirFormulario">+ Registrar</button>
        }
    </div>

    @if (resumen != null)
    {
        <div class="resumen-grid mb-3">
            <div class="resumen-card">
                <span class="resumen-label">Total</span>
                <span class="resumen-value">$@resumen.Total.ToString("N2")</span>
            </div>
            <div class="resumen-card">
                <span class="resumen-label">Diezmos</span>
                <span class="resumen-value">$@resumen.TotalTithe.ToString("N2")</span>
            </div>
            <div class="resumen-card">
                <span class="resumen-label">Ofrendas</span>
                <span class="resumen-value">$@resumen.TotalOffering.ToString("N2")</span>
            </div>
            <div class="resumen-card">
                <span class="resumen-label">Registros</span>
                <span class="resumen-value">@resumen.Count</span>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (!donaciones.Any())
    {
        <div class="empty-state"><span class="empty-icon">🪙</span><p>No hay donaciones registradas.</p></div>
    }
    else
    {
        <div class="donaciones-list">
            @foreach (var d in donaciones)
            {
                <div class="donacion-row">
                    <div class="donacion-icon">@TipoIcono(d.Type)</div>
                    <div class="flex-1">
                        <strong>$@d.Amount.ToString("N2") <small class="text-muted">@d.Currency</small></strong>
                        <div class="donacion-meta">
                            <span class="chip">@TipoNombre(d.Type)</span>
                            <span class="chip">@MetodoNombre(d.PaymentMethod)</span>
                            <span class="chip @EstadoClase(d.Status)">@EstadoNombre(d.Status)</span>
                        </div>
                        <small class="text-muted">@d.UserName @(d.Concept != null ? $"• {d.Concept}" : "") • @FormatFecha(d.DonatedAt)</small>
                    </div>
                    @if (permiso?.PuedeEliminar == true)
                    {
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => Eliminar(d.Id)">×</button>
                    }
                </div>
            }
        </div>
    }
</div>

@if (mostrarFormulario)
{
    <div class="modal-overlay" @onclick="CerrarFormulario">
        <div class="modal-card" @onclick:stopPropagation>
            <h4>Registrar Donación</h4>
            <div class="row mb-3">
                <div class="col">
                    <label class="form-label">Monto *</label>
                    <input type="number" step="0.01" class="form-control" @bind="form.Amount" />
                </div>
                <div class="col">
                    <label class="form-label">Tipo</label>
                    <select class="form-select" @bind="form.Type">
                        <option value="offering">Ofrenda</option>
                        <option value="tithe">Diezmo</option>
                        <option value="donation">Donación</option>
                        <option value="special_collection">Colecta especial</option>
                        <option value="other">Otro</option>
                    </select>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Método de pago</label>
                <select class="form-select" @bind="form.PaymentMethod">
                    <option value="cash">Efectivo</option>
                    <option value="transfer">Transferencia</option>
                    <option value="card">Tarjeta</option>
                    <option value="other">Otro</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Concepto</label>
                <input class="form-control" @bind="form.Concept" />
            </div>
            <div class="mb-3">
                <label><input type="checkbox" @bind="form.IsAnonymous" /> Donación anónima</label>
            </div>

            @if (errorForm != null) { <div class="alert alert-danger py-2">@errorForm</div> }

            <div class="d-flex gap-2 justify-content-end">
                <button class="btn btn-secondary" @onclick="CerrarFormulario">Cancelar</button>
                <button class="btn btn-primary" @onclick="Guardar" disabled="@guardando">
                    @(guardando ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<DonacionDto> donaciones = [];
    private DonacionResumen? resumen;
    private ModuloPermiso? permiso;
    private bool cargando = true, mostrarFormulario, guardando;
    private string? errorForm;
    private DonacionForm form = new();

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        permiso = Session.ObtenerPermiso("donations");
        if (permiso?.PuedeVer != true) { Nav.NavigateTo("/"); return; }
        await Cargar();
    }

    private async Task Cargar()
    {
        cargando = true;
        donaciones = await Api.GetDonacionesAsync();
        resumen = await Api.GetDonacionesResumenAsync();
        cargando = false;
    }

    private void AbrirFormulario() { form = new(); errorForm = null; mostrarFormulario = true; }
    private void CerrarFormulario() => mostrarFormulario = false;

    private async Task Guardar()
    {
        if (form.Amount <= 0) { errorForm = "El monto debe ser mayor a cero."; return; }
        guardando = true;
        var r = await Api.CrearDonacionAsync(new
        {
            amount = form.Amount, type = form.Type,
            concept = form.Concept, paymentMethod = form.PaymentMethod,
            isAnonymous = form.IsAnonymous
        });
        guardando = false;
        if (r is null) { errorForm = "Error al guardar."; return; }
        mostrarFormulario = false;
        await Cargar();
    }

    private async Task Eliminar(uint id)
    {
        if (await Api.EliminarDonacionAsync(id)) await Cargar();
    }

    private static string FormatFecha(string? f) =>
        DateTime.TryParse(f, out var d) ? d.ToString("dd MMM yyyy") : (f ?? "");

    private static string TipoIcono(string t) => t switch
    { "tithe" => "🌾", "offering" => "🙏", "donation" => "💝", "special_collection" => "📦", _ => "🪙" };
    private static string TipoNombre(string t) => t switch
    { "tithe" => "Diezmo", "offering" => "Ofrenda", "donation" => "Donación", "special_collection" => "Colecta", _ => "Otro" };
    private static string MetodoNombre(string m) => m switch
    { "cash" => "Efectivo", "transfer" => "Transferencia", "card" => "Tarjeta", _ => "Otro" };
    private static string EstadoNombre(string s) => s switch
    { "completed" => "Completada", "pending" => "Pendiente", "rejected" => "Rechazada", "refunded" => "Reembolsada", _ => s };
    private static string EstadoClase(string s) => s switch
    { "completed" => "chip-success", "pending" => "chip-warning", _ => "" };
}
