@page "/noticias"
@inject ApiService Api
@inject SessionService Session
@inject NavigationManager Nav

<div class="module-container">
    <div class="module-header">
        <h2>📰 Noticias</h2>
        @if (permiso?.PuedeCrear == true)
        {
            <button class="btn btn-primary" @onclick="AbrirFormulario">+ Nueva</button>
        }
    </div>

    @if (cargando)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (!noticias.Any())
    {
        <div class="empty-state"><span class="empty-icon">📭</span><p>No hay noticias publicadas.</p></div>
    }
    else
    {
        <div class="items-grid">
            @foreach (var n in noticias)
            {
                <div class="news-card">
                    @if (!string.IsNullOrEmpty(n.ImageUrl))
                    {
                        <img src="@n.ImageUrl" class="news-image" alt="@n.Title" />
                    }
                    else
                    {
                        <div class="news-image-placeholder">📰</div>
                    }
                    <div class="news-body">
                        <div class="news-meta">
                            @if (n.IsFeatured) { <span class="badge-featured">⭐ Destacada</span> }
                            @if (n.CategoryName != null) { <span class="badge-tipo">@n.CategoryName</span> }
                            @if (!n.IsPublished) { <span class="badge-estado borrador">Borrador</span> }
                            @if (EsProgramada(n)) { <span class="badge-scheduled">🕒 Programada</span> }
                        </div>
                        <h5 class="news-title">@n.Title</h5>
                        @if (n.Summary != null) { <p class="news-summary">@n.Summary</p> }
                        <div class="news-footer">
                            <small class="text-muted">@n.AuthorName • 👁️ @n.Views</small>
                            <div class="item-actions">
                                @if (permiso?.PuedeEditar == true)
                                {
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => AbrirEditar(n)">Editar</button>
                                }
                                @if (permiso?.PuedeEliminar == true)
                                {
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => Eliminar(n.Id)">🗑️</button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (mostrarFormulario)
{
    <div class="modal-overlay" @onclick="CerrarFormulario">
        <div class="modal-card" @onclick:stopPropagation>
            <h4>@(editandoId.HasValue ? "Modificar noticia" : "Nueva noticia")</h4>
            <div class="mb-3">
                <label class="form-label">Título *</label>
                <input class="form-control" @bind="form.Title" />
            </div>
            <div class="mb-3">
                <label class="form-label">Categoría</label>
                <select class="form-select" @bind="form.CategoryId">
                    <option value="">Sin categoría</option>
                    @foreach (var c in categorias)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Resumen</label>
                <textarea class="form-control" @bind="form.Summary" rows="2"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Contenido</label>
                <textarea class="form-control" @bind="form.Content" rows="4"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">URL de imagen</label>
                <input class="form-control" @bind="form.ImageUrl" placeholder="https://..." />
            </div>
            <div class="d-flex gap-3 mb-3">
                <label><input type="checkbox" @bind="form.IsPublished" /> Publicar</label>
                <label><input type="checkbox" @bind="form.IsFeatured" /> Destacar</label>
            </div>
            <div class="notification-box">
                <div class="notification-box-title">🔔 Recordatorio</div>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="newsNotify" @bind="form.SendNotification" />
                    <label class="form-check-label" for="newsNotify">Enviar notificación a los usuarios correspondientes</label>
                </div>
                <div class="responsive-form-grid">
                    <div>
                        <label class="form-label">Publicar o enviar el mensaje</label>
                        <input type="datetime-local" class="form-control"
                               value="@FechaInput(form.PublishedAt)"
                               @onchange="ActualizarFechaPublicacion" />
                    </div>
                    @if (form.SendNotification)
                    {
                        <div>
                            <label class="form-label">Recordatorio adicional</label>
                            <select class="form-select" @bind="form.ReminderMinutes">
                                <option value="0">Sin recordatorio adicional</option>
                                <option value="15">15 minutos antes</option>
                                <option value="30">30 minutos antes</option>
                                <option value="60">1 hora antes</option>
                                <option value="180">3 horas antes</option>
                                <option value="1440">1 día antes</option>
                                <option value="2880">2 días antes</option>
                                <option value="10080">1 semana antes</option>
                            </select>
                        </div>
                    }
                </div>
                <small class="text-muted d-block mt-2">La notificación respetará las preferencias de eventos, noticias y recordatorios de cada perfil.</small>
            </div>

            @if (errorForm != null) { <div class="alert alert-danger py-2">@errorForm</div> }

            <div class="d-flex gap-2 justify-content-end">
                <button class="btn btn-secondary" @onclick="CerrarFormulario">Cancelar</button>
                <button class="btn btn-primary" @onclick="Guardar" disabled="@guardando">
                    @(guardando ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<NoticiaDto> noticias = [];
    private List<CategoriaDto> categorias = [];
    private ModuloPermiso? permiso;
    private bool cargando = true, mostrarFormulario, guardando;
    private string? errorForm;
    private NoticiaForm form = new();
    private uint? editandoId;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        permiso = Session.ObtenerPermiso("news");
        if (permiso?.PuedeVer != true) { Nav.NavigateTo("/"); return; }
        categorias = await Api.GetNoticiasCategoriasAsync();
        await Cargar();
    }

    private async Task Cargar()
    {
        cargando = true;
        noticias = await Api.GetNoticiasAsync();
        cargando = false;
    }

    private void AbrirFormulario()
    {
        editandoId = null;
        form = new NoticiaForm
        {
            PublishedAt = DateTime.Now,
            SendNotification = true,
            ReminderMinutes = 0
        };
        errorForm = null;
        mostrarFormulario = true;
    }

    private void AbrirEditar(NoticiaDto noticia)
    {
        editandoId = noticia.Id;
        form = new NoticiaForm
        {
            Title = noticia.Title,
            Summary = noticia.Summary,
            Content = noticia.Content,
            ImageUrl = noticia.ImageUrl,
            CategoryId = noticia.CategoryId,
            IsPublished = noticia.IsPublished,
            IsFeatured = noticia.IsFeatured,
            PublishedAt = ParseFecha(noticia.PublishedAt) ?? DateTime.Now,
            SendNotification = true,
            ReminderMinutes = 0
        };
        errorForm = null;
        mostrarFormulario = true;
    }

    private void CerrarFormulario() => mostrarFormulario = false;

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(form.Title)) { errorForm = "El título es requerido."; return; }
        guardando = true;
        var r = editandoId.HasValue
            ? await Api.ActualizarNoticiaAsync(editandoId.Value, form)
            : await Api.CrearNoticiaAsync(form);
        guardando = false;
        if (r is null) { errorForm = "Error al guardar."; return; }
        mostrarFormulario = false;
        await Cargar();
    }

    private async Task Eliminar(uint id)
    {
        if (await Api.EliminarNoticiaAsync(id)) await Cargar();
    }

    private void ActualizarFechaPublicacion(ChangeEventArgs e)
    {
        form.PublishedAt = DateTime.TryParse(e.Value?.ToString(), out var fecha) ? fecha : null;
    }

    private static string FechaInput(DateTime? fecha) =>
        fecha?.ToString("yyyy-MM-ddTHH:mm") ?? "";

    private static DateTime? ParseFecha(string? value) =>
        DateTime.TryParse(value, out var fecha) ? fecha : null;

    private static bool EsProgramada(NoticiaDto noticia) =>
        ParseFecha(noticia.PublishedAt) is DateTime fecha && fecha > DateTime.Now;
}
