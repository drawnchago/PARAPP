@page "/intenciones"
@inject ApiService Api
@inject SessionService Session
@inject NavigationManager Nav

<div class="module-container">
    <div class="module-header">
        <h2>🕯️ Intenciones de Misa</h2>
        @if (permiso?.PuedeCrear == true)
        {
            <button class="btn btn-primary" @onclick="AbrirFormulario">+ Nueva</button>
        }
    </div>

    @if (cargando)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (!intenciones.Any())
    {
        <div class="empty-state"><span class="empty-icon">🙏</span><p>No hay intenciones registradas.</p></div>
    }
    else
    {
        <div class="items-grid">
            @foreach (var i in intenciones)
            {
                <div class="item-card">
                    <div class="item-card-header">
                        <span class="badge-tipo">@TipoIcono(i.Type) @TipoNombre(i.Type)</span>
                        <span class="badge-estado @EstadoClase(i.Status)">@EstadoNombre(i.Status)</span>
                    </div>
                    <p class="intention-text">"@i.Intention"</p>
                    <div class="item-meta">
                        @if (i.MassDate != null) { <span>📅 @FormatFecha(i.MassDate)</span> }
                        @if (i.Donation.HasValue) { <span>💰 $@i.Donation.Value.ToString("N2")</span> }
                    </div>
                    <div class="item-footer">
                        <small class="text-muted">@i.UserName</small>
                        @if (permiso?.PuedeEditar == true)
                        {
                            <select class="form-select form-select-sm w-auto"
                                    value="@i.Status"
                                    @onchange="e => CambiarEstado(i, e.Value?.ToString())">
                                <option value="pending">Pendiente</option>
                                <option value="scheduled">Programada</option>
                                <option value="celebrated">Celebrada</option>
                                <option value="cancelled">Cancelada</option>
                            </select>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (mostrarFormulario)
{
    <div class="modal-overlay" @onclick="CerrarFormulario">
        <div class="modal-card" @onclick:stopPropagation>
            <h4>Nueva Intención</h4>
            <div class="mb-3">
                <label class="form-label">Intención *</label>
                <textarea class="form-control" @bind="form.Intention" rows="3"
                          placeholder="Por el eterno descanso de..."></textarea>
            </div>
            <div class="row mb-3">
                <div class="col">
                    <label class="form-label">Tipo</label>
                    <select class="form-select" @bind="form.Type">
                        <option value="petition">Petición</option>
                        <option value="deceased">Difunto</option>
                        <option value="living">Por los vivos</option>
                        <option value="thanksgiving">Acción de gracias</option>
                        <option value="other">Otro</option>
                    </select>
                </div>
                <div class="col">
                    <label class="form-label">Fecha de misa</label>
                    <input type="date" class="form-control"
                           @onchange="e => form.MassDate = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!)" />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Donativo (opcional)</label>
                <input type="number" step="0.01" class="form-control" @bind="form.Donation" />
            </div>

            @if (errorForm != null) { <div class="alert alert-danger py-2">@errorForm</div> }

            <div class="d-flex gap-2 justify-content-end">
                <button class="btn btn-secondary" @onclick="CerrarFormulario">Cancelar</button>
                <button class="btn btn-primary" @onclick="Guardar" disabled="@guardando">
                    @(guardando ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<IntencionDto> intenciones = [];
    private ModuloPermiso? permiso;
    private bool cargando = true, mostrarFormulario, guardando;
    private string? errorForm;
    private IntencionForm form = new();

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        permiso = Session.ObtenerPermiso("intentions");
        if (permiso?.PuedeVer != true) { Nav.NavigateTo("/"); return; }
        await Cargar();
    }

    private async Task Cargar()
    {
        cargando = true;
        intenciones = await Api.GetIntencionesAsync();
        cargando = false;
    }

    private void AbrirFormulario() { form = new(); errorForm = null; mostrarFormulario = true; }
    private void CerrarFormulario() => mostrarFormulario = false;

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(form.Intention)) { errorForm = "La intención es requerida."; return; }
        guardando = true;
        var r = await Api.CrearIntencionAsync(new
        {
            intention = form.Intention, type = form.Type,
            massDate = form.MassDate?.ToString("yyyy-MM-dd"), donation = form.Donation
        });
        guardando = false;
        if (r is null) { errorForm = "Error al guardar."; return; }
        mostrarFormulario = false;
        await Cargar();
    }

    private async Task CambiarEstado(IntencionDto i, string? estado)
    {
        if (estado is null) return;
        await Api.ActualizarIntencionAsync(i.Id, new { status = estado });
        await Cargar();
    }

    private static string FormatFecha(string? f) =>
        DateTime.TryParse(f, out var d) ? d.ToString("dd MMM yyyy") : (f ?? "");
    private static string TipoIcono(string t) => t switch
    { "deceased" => "🕊️", "living" => "❤️", "thanksgiving" => "🙏", "petition" => "✨", _ => "🕯️" };
    private static string TipoNombre(string t) => t switch
    { "deceased" => "Difunto", "living" => "Por los vivos", "thanksgiving" => "Gracias", "petition" => "Petición", _ => "Otro" };
    private static string EstadoNombre(string s) => s switch
    { "pending" => "Pendiente", "scheduled" => "Programada", "celebrated" => "Celebrada", "cancelled" => "Cancelada", _ => s };
    private static string EstadoClase(string s) => s switch
    { "celebrated" => "completada", "scheduled" => "programada", "cancelled" => "cancelada", _ => "borrador" };
}
