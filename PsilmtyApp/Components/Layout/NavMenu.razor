@inject SessionService Session
@inject NavigationManager Nav

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">PsilmtyApp</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        @if (Session.IsAuthenticated)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <span class="nav-emoji">🏠</span> Inicio
                </NavLink>
            </div>

            @foreach (var m in Session.Session!.Modulos.Where(x => x.PuedeVer && !string.IsNullOrEmpty(x.Ruta)))
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="@m.Ruta!.TrimStart('/')">
                        <span class="nav-emoji">@IconoEmoji(m.Clave)</span> @m.Nombre
                    </NavLink>
                </div>
            }

            <div class="nav-item px-3 mt-auto">
                <button class="nav-link btn btn-link text-start w-100" @onclick="Salir">
                    <span class="nav-emoji">🚪</span> Salir
                </button>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="login">
                    <span class="nav-emoji">🔐</span> Iniciar sesión
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    private void Salir()
    {
        Session.Logout();
        Nav.NavigateTo("/login");
    }

    private static string IconoEmoji(string clave) => clave switch
    {
        "adoration"     => "🎵",
        "adoraciones"   => "🎵",
        "groups"        => "🎸",
        "adoradores"    => "🎸",
        "calendar"      => "📅",
        "eventos"       => "📅",
        "settings"      => "⚙️",
        "configuracion" => "⚙️",
        "home"          => "🏠",
        "news"          => "📰",
        "notifications" => "🔔",
        "donations"     => "💝",
        "users"         => "👥",
        "sacraments"    => "⛪",
        "gallery"       => "🖼️",
        "intentions"    => "🕯️",
        "requests"      => "📋",
        "countries"     => "🌎",
        "states"        => "🗺️",
        "neighborhoods" => "🏘️",
        _               => "📦"
    };
}
