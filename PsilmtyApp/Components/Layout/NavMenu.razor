@inject SessionService Session
@inject NavigationManager Nav

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">PsilmtyApp</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        @if (Session.IsAuthenticated)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <span class="nav-emoji">🏠</span> Inicio
                </NavLink>
            </div>

            @foreach (var m in NivelSuperior)
            {
                @RenderNodo(m)
            }

            <div class="nav-item px-3 mt-auto">
                <button class="nav-link btn btn-link text-start w-100" @onclick="Salir">
                    <span class="nav-emoji">🚪</span> Salir
                </button>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="login">
                    <span class="nav-emoji">🔐</span> Iniciar sesión
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    // Grupos expandidos (por id del módulo padre). Por defecto vacío => todos compactados.
    private readonly HashSet<uint> expandidos = [];

    // Módulos visibles (sin el "home", que se muestra como enlace fijo de Inicio).
    private List<ModuloPermiso> Mods =>
        Session.Session?.Modulos.Where(x => x.PuedeVer && x.Clave != "home").ToList() ?? [];

    // TODOS los hijos (contenedores y hojas) agrupados por su módulo padre.
    private Dictionary<uint, List<ModuloPermiso>> HijosPorPadre =>
        Mods.Where(x => x.ParentId != null)
            .GroupBy(x => x.ParentId!.Value)
            .ToDictionary(g => g.Key, g => g.ToList());

    // Nivel superior: módulos sin padre.
    private IEnumerable<ModuloPermiso> NivelSuperior => Mods.Where(x => x.ParentId == null);

    // Render recursivo de un nodo: si tiene hijos => grupo colapsable; si no => enlace.
    private RenderFragment<ModuloPermiso> RenderNodo => modulo =>
    @<text>
        @if (HijosPorPadre.TryGetValue(modulo.ModuloId, out var hijos))
        {
            var abierto = expandidos.Contains(modulo.ModuloId);
            <div class="nav-group">
                <button type="button" class="nav-link nav-group-header"
                        @onclick="() => ToggleGrupo(modulo.ModuloId)" @onclick:stopPropagation="true">
                    <span class="nav-emoji">@Ico(modulo.Icono)</span>
                    <span class="nav-group-title">@modulo.Nombre</span>
                    <span class="nav-group-caret">@(abierto ? "▾" : "▸")</span>
                </button>
                @if (abierto)
                {
                    <div class="nav-group-children">
                        @foreach (var h in hijos)
                        {
                            @RenderNodo(h)
                        }
                    </div>
                }
            </div>
        }
        else if (!string.IsNullOrEmpty(modulo.Ruta))
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="@modulo.Ruta!.TrimStart('/')">
                    <span class="nav-emoji">@Ico(modulo.Icono)</span> @modulo.Nombre
                </NavLink>
            </div>
        }
    </text>;

    private void ToggleGrupo(uint parentId)
    {
        if (!expandidos.Remove(parentId))
            expandidos.Add(parentId);
    }

    // El icono proviene de la base de datos; fallback genérico si viniera vacío.
    private static string Ico(string? icon) => string.IsNullOrEmpty(icon) ? "📦" : icon;

    private void Salir()
    {
        Session.Logout();
        Nav.NavigateTo("/login");
    }
}
